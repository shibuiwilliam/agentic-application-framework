{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaf.dev/schemas/eval-suite.json",
  "title": "Eval Suite",
  "type": "object",
  "required": ["name", "threshold", "cases"],
  "properties": {
    "name": { "type": "string" },
    "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "intent", "expected"],
        "properties": {
          "id": { "type": "string" },
          "intent": { "type": "string" },
          "expected": { "type": "string" },
          "min_score": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
