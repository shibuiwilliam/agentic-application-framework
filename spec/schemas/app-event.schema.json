{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aaf.dev/schemas/app-event.json",
  "title": "App Event",
  "type": "object",
  "required": ["event_id", "event_type", "source", "situation", "session_id", "timestamp"],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["app_id", "surface"],
      "properties": {
        "app_id": { "type": "string" },
        "surface": { "type": "string" }
      }
    },
    "situation": {
      "type": "object",
      "required": ["session"],
      "properties": {
        "current_entities": { "type": "array" },
        "current_screen": {
          "type": "object",
          "properties": {
            "route": { "type": "string" },
            "component": { "type": "string" },
            "visible_fields": { "type": "array", "items": { "type": "string" } }
          }
        },
        "session": {
          "type": "object",
          "required": ["user_id", "role", "scopes", "locale", "tenant_id"],
          "properties": {
            "user_id": { "type": "string" },
            "role": { "type": "string" },
            "scopes": { "type": "array", "items": { "type": "string" } },
            "locale": { "type": "string" },
            "tenant_id": { "type": "string" }
          }
        },
        "constraints": {
          "type": "object",
          "properties": {
            "time_budget_ms": { "type": "integer", "minimum": 0 },
            "cost_budget_usd": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "payload": {},
    "session_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "trace_id": { "type": "string" }
  }
}
